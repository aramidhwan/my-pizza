pipeline {
    agent any

    environment {
        RESOURCE_GROUP = "myPizzaRSG"
        CLUSTER_NAME = "myPizzaCluster"

        // Git 저장소 기준 상대경로 사용
        KUBE_INIT_DIR = "init/kubernetes"
        CERT_PATH = "gateway/src/main/resources/mypizza.crt"
        KEY_PATH = "gateway/src/main/resources/mypizza-decrypted.key"
        NAMESPACE = "dev-db"

        // AZURE_SUBSCRIPTION_ID : az account show 해서 "id" 항목
        // 나머지 항목들 : az ad sp create-for-rbac --name jenkins-sp --role contributor --scopes /subscriptions/<AZURE_SUBSCRIPTION_ID>
        // AZURE_CLIENT_ID					: "appId" 항목
        // AZURE_CLIENT_SECRET 		: "password" 항목
        // AZURE_TENANT_ID 				: "tenant" 항목
        AZURE_CLIENT_ID = "cdf1d46e-3f80-49c7-b414-f10d3c595b56"
        AZURE_CLIENT_SECRET = "idV8Q~LDZtuJPSuqFuItUabGNLElOqSfMcxBRcz_"
        AZURE_TENANT_ID = "a781af68-05e4-446a-92a7-d9a45d90d58c"
        AZURE_SUBSCRIPTION_ID = "eee3d1d2-f4eb-444b-8dcf-2e731df0aac7"
    }

    stages {
        stage('소스코드 체크아웃') {
            steps {
                checkout scm
            }
        }

        stage('Kubernetes 환경구성') {
            steps {
                sh '''
                    echo Azure 로그인
                    az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID --output none
                    az account set --subscription $AZURE_SUBSCRIPTION_ID

                    echo ■ Getting AKS Credentials
                    az aks get-credentials --resource-group $RESOURCE_GROUP --name $CLUSTER_NAME --overwrite-existing

                    echo ■ Creating MySql
                    kubectl apply -f $KUBE_INIT_DIR/deployment-dev-db-secret.yml
                    kubectl apply -f $KUBE_INIT_DIR/deployment-mysql.yml

                    echo ⏳ Waiting for MySQL pod to be ready...
                    kubectl wait --namespace $NAMESPACE --for=condition=ready pod -l app=mysql --timeout=120s

                    echo ■ Creating Zookeeper
                    kubectl apply -f $KUBE_INIT_DIR/deployment-zookeeper.yml

                    echo ■ Waiting for service-kafka to be ready
                    sleep 3		# endpoint("service-kafka")가 생성될 때까지 대기

                    echo ■ Creating Kafka
                    kubectl apply -f $KUBE_INIT_DIR/deployment-kafka.yml

                    MYSQL_POD=$(kubectl get pod -n $NAMESPACE -l app=mysql -o jsonpath='{.items[0].metadata.name}')

                    echo ■ MYSQL 준비될 때까지 대기...
                    for i in $(seq 1 10); do
                        kubectl exec -n $NAMESPACE $MYSQL_POD -- mysql -u root -pshin22 -e "SELECT 'MYSQL READY!'" && break
                        echo "⌛ MySQL READY 대기 중... ($i/10)"
                        sleep 5
                    done

                    echo 🧩 Applying SQL from mypizza.sql...
                    kubectl exec -n $NAMESPACE -i $(kubectl get pod -n $NAMESPACE -l app=mysql -o jsonpath='{.items[0].metadata.name}') -- mysql -u root -pshin22 -h 127.0.0.1 < init/mypizza.sql
                '''
            }
        }
    }
}
