pipeline {
    agent any

    environment {
        PROJECT_NAME = 'my-pizza'
        ACR_NAME = 'mypizzaacr.azurecr.io'      // ACR 주소
        IMAGE_TAG = "latest"
        CRT_NAME = "acr-chain.crt"

        RESOURCE_GROUP = "myPizzaRSG"
        CLUSTER_NAME = "myPizzaCluster"

        // AZURE_SUBSCRIPTION_ID : az account show 해서 "id" 항목
        // 나머지 항목들 : az ad sp create-for-rbac --name jenkins-sp --role contributor --scopes /subscriptions/<AZURE_SUBSCRIPTION_ID>
        // AZURE_CLIENT_ID					: "appId" 항목
        // AZURE_CLIENT_SECRET 		: "password" 항목
        // AZURE_TENANT_ID 				: "tenant" 항목
        AZURE_CLIENT_ID = "cdf1d46e-3f80-49c7-b414-f10d3c595b56"
        AZURE_CLIENT_SECRET = "idV8Q~LDZtuJPSuqFuItUabGNLElOqSfMcxBRcz_"
        AZURE_TENANT_ID = "a781af68-05e4-446a-92a7-d9a45d90d58c"
        AZURE_SUBSCRIPTION_ID = "eee3d1d2-f4eb-444b-8dcf-2e731df0aac7"
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Detect Changes') {
            steps {
                script {
                    def changedFiles = sh(script: "git diff --name-only HEAD~1 HEAD", returnStdout: true).trim().split('\n')

                    echo "📁 변경된 파일 목록:"
                    changedFiles.each { echo it }

                    if (changedFiles.size() == 0) {
                        echo '⚠️ 변경된 파일이 없습니다.'
                    } else {
                        echo "✅ 변경 감지됨!"
                    }

                    env.BUILD_COMMON   = changedFiles.any { it.startsWith("common/") }.toString()
                    env.BUILD_ORDER    = changedFiles.any { it.startsWith("order/") }.toString()
                    env.BUILD_STORE    = changedFiles.any { it.startsWith("store/") }.toString()
                    env.BUILD_DELIVERY = changedFiles.any { it.startsWith("delivery/") }.toString()
                    env.BUILD_MYPAGE   = changedFiles.any { it.startsWith("customercenter/") }.toString()
                }
            }
        }

        stage('Build Services') {
            steps {
                script {
			            sh '''
			                chmod +x ./common/gradlew || true
			                chmod +x ./order/gradlew || true
			                chmod +x ./store/gradlew || true
			                chmod +x ./delivery/gradlew || true
			                chmod +x ./customercenter/gradlew || true
			            '''
                    if (env.BUILD_COMMON == 'true') {
                        echo '🚧 common 빌드'
                        sh 'cd common && ./gradlew build --no-daemon'
                    }
                    if (env.BUILD_ORDER == 'true') {
                        echo '🚧 order 빌드'
                        sh 'cd order && ./gradlew build --no-daemon'
                    }
                    if (env.BUILD_STORE == 'true') {
                        echo '🚧 store 빌드'
                        sh 'cd store && ./gradlew build --no-daemon'
                    }
                    if (env.BUILD_DELIVERY == 'true') {
                        echo '🚧 delivery 빌드'
                        sh 'cd delivery && ./gradlew build --no-daemon'
                    }
                    if (env.BUILD_MYPAGE == 'true') {
                        echo '🚧 mypage 빌드'
                        sh 'cd customercenter && ./gradlew build --no-daemon'
                    }
                }
            }
        }

        stage('Docker Build & Push to ACR') {
            steps {
                script {
                        sh '''
                            echo ■ ACR 인증서 자동 추출 및 시스템 등록 시작
                            # /tmp에 먼저 저장 (권한 문제 회피)
                            echo | openssl s_client -showcerts -connect ${ACR_NAME}:443 </dev/null | sed -ne '/-BEGIN CERTIFICATE-/,/-END CERTIFICATE-/p' > /tmp/${CRT_NAME}

                            # 루트 권한으로 복사 및 등록
                            sudo cp /tmp/${CRT_NAME} /usr/local/share/ca-certificates/${CRT_NAME}
                            sudo update-ca-certificates

                            echo ■ Azure 로그인
                            az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID
                            az account set --subscription $AZURE_SUBSCRIPTION_ID

                            echo ■ Getting AKS Credentials
                            az aks get-credentials --resource-group $RESOURCE_GROUP --name $CLUSTER_NAME --overwrite-existing
                            az acr login --name ${ACR_NAME%%.*} --output none
                        '''

                        def pushImage = { serviceDir, imageName ->
                            def fullImage = "${env.ACR_NAME}/${imageName}:${env.IMAGE_TAG}"
                            sh """
                                docker build -t ${fullImage} ${serviceDir}
                                docker push ${fullImage}
                            """
                        }

                        if (env.BUILD_COMMON == 'true') {
                            pushImage('common', 'common')
                        }
                        if (env.BUILD_ORDER == 'true') {
                            pushImage('order', 'order')
                        }
                        if (env.BUILD_STORE == 'true') {
                            pushImage('store', 'store')
                        }
                        if (env.BUILD_DELIVERY == 'true') {
                            pushImage('delivery', 'delivery')
                        }
                        if (env.BUILD_MYPAGE == 'true') {
                            pushImage('customercenter', 'mypage')
                        }

                }
            }
        }
    }

    post {
        success {
            echo '✅ 전체 파이프라인 완료'
        }
        failure {
            echo '❌ 오류 발생 - 로그를 확인하세요'
        }
    }
}