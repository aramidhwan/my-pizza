<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.study.mypizza.common.mapper.CustomerMapper">

    <!--  Member insert쿼리-->
    <insert id="insertMember">

        <selectKey keyProperty="customer_no" resultType="int" order="BEFORE">
            SELECT NEXT VALUE FOR member_seq
        </selectKey>

        INSERT INTO member (member_Id, username, age)
        VALUES (#{member_Id}, #{member.username}, #{member.age})
    </insert>

    <!--  Member select 쿼리-->
    <select id="selectCustomer" resultType="com.study.mypizza.common.dto.CustomerDto">
        SELECT * FROM T_CUSTOMER
        WHERE EMAIL = #{email}
    </select>

</mapper>